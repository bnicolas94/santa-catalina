generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empleado {
  id                   String               @id @default(uuid())
  nombre               String
  apellido             String?
  dni                  String?              @unique
  email                String?              @unique
  password             String?
  rol                  String
  telefono             String?
  activo               Boolean              @default(true)
  fechaIngreso         DateTime?            @map("fecha_ingreso")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  sueldoBaseMensual    Float                @default(0) @map("sueldo_base_mensual")
  jornal               Float                @default(0)
  valorHoraNormal      Float?               @map("valor_hora_normal")
  cicloPago            String               @default("SEMANAL") @map("ciclo_pago")
  porcentajeHoraExtra  Float                @default(50) @map("porcentaje_hora_extra")
  valorHoraExtra       Float                @default(0) @map("valor_hora_extra")
  porcentajeFeriado    Float                @default(100) @map("porcentaje_feriado")
  horasTrabajoDiarias  Float                @default(8) @map("horas_trabajo_diarias")
  diasTrabajoSemana    String               @default("Lunes a Viernes") @map("dias_trabajo_semana")
  horarioEntrada       String?              @map("horario_entrada")
  horarioSalida        String?              @map("horario_salida")
  codigoBiometrico     String?              @unique @map("codigo_biometrico")
  ubicacionId          String?              @map("id_ubicacion")
  rolId                String?              @map("id_rol")
  areaId               String?              @map("id_area")
  puestoId             String?              @map("id_puesto")
  turnoId              String?              @map("id_turno")
  preferenciasReporte  Json?                @map("preferencias_reporte")
  asignaciones         AsignacionOperario[]
  asignacionesVehiculo AsignacionVehiculo[] @relation("AsignacionesVehiculo")
  rolRel               RolEmpleado?         @relation(fields: [rolId], references: [id])
  ubicacion            Ubicacion?           @relation(fields: [ubicacionId], references: [id])
  area                 Area?                @relation("EmpleadoArea", fields: [areaId], references: [id])
  puesto               Puesto?              @relation("EmpleadoPuesto", fields: [puestoId], references: [id])
  turno                TurnoTrabajo?        @relation("EmpleadoTurno", fields: [turnoId], references: [id])
  areasResponsable     Area[]               @relation("ResponsableArea")
  fichadas             FichadaEmpleado[]
  liquidaciones        LiquidacionSueldo[]
  lotesCoordinados     Lote[]               @relation("CoordinadorLote")
  prestamos            PrestamoEmpleado[]
  rendiciones          RendicionChofer[]    @relation("RendicionesChofer")
  rutasChofer          Ruta[]               @relation("ChoferRuta")
  documentos           DocumentoEmpleado[]
  evaluaciones         Evaluacion[]         @relation("EmpleadoEvaluado")
  evaluacionesHechas   Evaluacion[]         @relation("Evaluador")
  inasistencias        Inasistencia[]

  @@map("empleados")
}

model Evaluacion {
  id            String   @id @default(uuid())
  fecha         DateTime @default(now())
  calificacion  String // Excelente, Bueno, Regular, Malo
  puntosFuertes String?  @map("puntos_fuertes")
  puntosMejora  String?  @map("puntos_mejora")
  comentarios   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  empleadoId  String   @map("id_empleado")
  evaluadorId String   @map("id_evaluador")

  empleado  Empleado @relation("EmpleadoEvaluado", fields: [empleadoId], references: [id], onDelete: Cascade)
  evaluador Empleado @relation("Evaluador", fields: [evaluadorId], references: [id])

  @@map("evaluaciones_desempeno")
}

model Proveedor {
  id               String            @id @default(uuid())
  nombre           String
  contacto         String?
  telefono         String?
  email            String?
  direccion        String?
  categoria        String?
  activo           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  insumos          Insumo[]
  movimientosStock MovimientoStock[]

  @@map("proveedores")
}

model Producto {
  id                  String                    @id @default(uuid())
  nombre              String
  codigoInterno       String                    @unique @map("codigo_interno")
  costoUnitario       Float                     @default(0) @map("costo_unitario")
  planchasPorPaquete  Int                       @default(6) @map("planchas_por_paquete")
  paquetesPorRonda    Int                       @default(14) @map("paquetes_por_ronda")
  vidaUtilHoras       Int                       @default(48) @map("vida_util_horas")
  tempConservacionMax Float                     @default(4) @map("temp_conservacion_max")
  activo              Boolean                   @default(true)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  alias               String?
  fichasTecnicas      FichaTecnica[]
  lotes               Lote[]
  movimientosProducto MovimientoProducto[]
  presentaciones      Presentacion[]
  requerimientos      RequerimientoProduccion[]
  stockUbicaciones    StockProducto[]

  @@map("productos")
}

model Presentacion {
  id             String                    @id @default(uuid())
  cantidad       Int
  precioVenta    Float                     @map("precio_venta")
  stockMinimo    Int                       @default(0) @map("stock_minimo")
  activo         Boolean                   @default(true)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  productoId     String                    @map("id_producto")
  detallePedidos DetallePedido[]
  movimientos    MovimientoProducto[]
  producto       Producto                  @relation(fields: [productoId], references: [id], onDelete: Cascade)
  requerimientos RequerimientoProduccion[]
  stocks         StockProducto[]

  @@unique([productoId, cantidad])
  @@map("presentaciones")
}

model FamiliaInsumo {
  id        String   @id @default(uuid())
  nombre    String   @unique
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  insumos   Insumo[]

  @@map("familias_insumo")
}

model Insumo {
  id                    String            @id @default(uuid())
  nombre                String
  unidadMedida          String            @map("unidad_medida")
  stockActual           Float             @default(0) @map("stock_actual")
  stockMinimo           Float             @default(0) @map("stock_minimo")
  precioUnitario        Float             @default(0) @map("precio_unitario")
  diasReposicion        Int               @default(1) @map("dias_reposicion")
  activo                Boolean           @default(true)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  proveedorId           String?           @map("id_proveedor")
  familiaId             String?           @map("id_familia")
  unidadSecundaria      String?           @map("unidad_secundaria")
  factorConversion      Float?            @map("factor_conversion")
  stockActualSecundario Float             @default(0) @map("stock_actual_secundario")
  fichasTecnicas        FichaTecnica[]
  familia               FamiliaInsumo?    @relation(fields: [familiaId], references: [id])
  proveedor             Proveedor?        @relation(fields: [proveedorId], references: [id])
  movimientos           MovimientoStock[]
  stocks                StockInsumo[]

  @@map("insumos")
}

model FichaTecnica {
  id                String   @id @default(uuid())
  cantidadPorUnidad Float    @map("cantidad_por_unidad")
  unidadMedida      String   @map("unidad_medida")
  merma             Float    @default(0)
  productoId        String   @map("id_producto")
  insumoId          String   @map("id_insumo")
  insumo            Insumo   @relation(fields: [insumoId], references: [id])
  producto          Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@unique([productoId, insumoId])
  @@map("fichas_tecnicas")
}

model Lote {
  id                  String               @id
  fechaProduccion     DateTime             @map("fecha_produccion")
  horaInicio          DateTime?            @map("hora_inicio")
  horaFin             DateTime?            @map("hora_fin")
  unidadesProducidas  Int                  @default(0) @map("unidades_producidas")
  unidadesRechazadas  Int                  @default(0) @map("unidades_rechazadas")
  motivoRechazo       String?              @map("motivo_rechazo")
  empleadosRonda      Int                  @default(1) @map("empleados_ronda")
  estado              String               @default("en_camara")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  ubicacionId         String               @map("id_ubicacion")
  productoId          String               @map("id_producto")
  coordinadorId       String?              @map("id_empleado_coord")
  detallePedidos      DetallePedido[]
  coordinador         Empleado?            @relation("CoordinadorLote", fields: [coordinadorId], references: [id])
  producto            Producto             @relation(fields: [productoId], references: [id])
  ubicacion           Ubicacion            @relation(fields: [ubicacionId], references: [id])
  movimientosProducto MovimientoProducto[]
  movimientosStock    MovimientoStock[]
  distribucion        Json?                @map("distribucion")

  @@map("lotes")
}

model Ubicacion {
  id                  String               @id @default(uuid())
  nombre              String               @unique
  tipo                String
  activo              Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  asignaciones        AsignacionOperario[]
  empleados           Empleado[]
  gastos              GastoOperativo[]
  lotes               Lote[]
  movimientosProducto MovimientoProducto[]
  movimientosStock    MovimientoStock[]
  pedidos             Pedido[]
  rutasOrigen         Ruta[]               @relation("OrigenRuta")
  stocksInsumo        StockInsumo[]
  stocks              StockProducto[]

  @@map("ubicaciones")
}

model StockProducto {
  id             String       @id @default(uuid())
  cantidad       Int          @default(0)
  updatedAt      DateTime     @updatedAt
  ubicacionId    String       @map("id_ubicacion")
  productoId     String       @map("id_producto")
  presentacionId String       @map("id_presentacion")
  presentacion   Presentacion @relation(fields: [presentacionId], references: [id])
  producto       Producto     @relation(fields: [productoId], references: [id])
  ubicacion      Ubicacion    @relation(fields: [ubicacionId], references: [id])

  @@unique([productoId, presentacionId, ubicacionId])
  @@map("stock_productos")
}

model MovimientoProducto {
  id             String       @id @default(uuid())
  tipo           String
  cantidad       Int
  signo          String
  fecha          DateTime     @default(now())
  observaciones  String?
  createdAt      DateTime     @default(now())
  ubicacionId    String       @map("id_ubicacion")
  productoId     String       @map("id_producto")
  presentacionId String       @map("id_presentacion")
  loteId         String?      @map("id_lote")
  entregaId      String?      @map("id_entrega")
  rutaId         String?      @map("id_ruta")
  entrega        Entrega?     @relation(fields: [entregaId], references: [id])
  lote           Lote?        @relation(fields: [loteId], references: [id])
  presentacion   Presentacion @relation(fields: [presentacionId], references: [id])
  producto       Producto     @relation(fields: [productoId], references: [id])
  ruta           Ruta?        @relation(fields: [rutaId], references: [id])
  ubicacion      Ubicacion    @relation(fields: [ubicacionId], references: [id])

  @@map("movimientos_producto")
}

model MovimientoStock {
  id                 String          @id @default(uuid())
  tipo               String
  cantidad           Float
  fecha              DateTime        @default(now())
  observaciones      String?
  costoTotal         Float?          @map("costo_total")
  estadoPago         String?         @default("pagado")
  createdAt          DateTime        @default(now())
  insumoId           String          @map("id_insumo")
  loteOrigenId       String?         @map("id_lote_origen")
  proveedorId        String?         @map("id_proveedor")
  gastoId            String?         @map("id_gasto")
  fechaVencimiento   DateTime?       @map("fecha_vencimiento")
  ubicacionId        String?         @map("id_ubicacion")
  cantidadSecundaria Float?          @map("cantidad_secundaria")
  numeroFactura      String?         @map("numero_factura")
  montoPagado        Float?          @default(0) @map("monto_pagado")
  gasto              GastoOperativo? @relation(fields: [gastoId], references: [id])
  insumo             Insumo          @relation(fields: [insumoId], references: [id])
  loteOrigen         Lote?           @relation(fields: [loteOrigenId], references: [id])
  proveedor          Proveedor?      @relation(fields: [proveedorId], references: [id])
  ubicacion          Ubicacion?      @relation(fields: [ubicacionId], references: [id])

  @@map("movimientos_stock")
}

model StockInsumo {
  id                 String    @id @default(uuid())
  cantidad           Float     @default(0)
  cantidadSecundaria Float     @default(0) @map("cantidad_secundaria")
  updatedAt          DateTime  @updatedAt
  ubicacionId        String    @map("id_ubicacion")
  insumoId           String    @map("id_insumo")
  insumo             Insumo    @relation(fields: [insumoId], references: [id])
  ubicacion          Ubicacion @relation(fields: [ubicacionId], references: [id])

  @@unique([insumoId, ubicacionId])
  @@map("stock_insumos")
}

model Cliente {
  id                String    @id @default(uuid())
  nombreComercial   String    @map("nombre_comercial")
  contactoNombre    String?   @map("contacto_nombre")
  contactoTelefono  String?   @map("contacto_telefono")
  direccion         String?
  latitud           Float?
  longitud          Float?
  zona              String?
  segmento          String?
  frecuenciaSemanal Int       @default(0) @map("frecuencia_semanal")
  pedidoPromedioU   Int       @default(0) @map("pedido_promedio_u")
  precioDiferencial Boolean   @default(false) @map("precio_diferencial")
  activo            Boolean   @default(true)
  fechaAlta         DateTime  @default(now()) @map("fecha_alta")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  calle             String?
  localidad         String?
  numero            String?
  entregas          Entrega[]
  pedidos           Pedido[]

  @@map("clientes")
}

model Pedido {
  id              String           @id @default(uuid())
  fechaPedido     DateTime         @map("fecha_pedido")
  fechaEntrega    DateTime         @map("fecha_entrega")
  estado          String           @default("pendiente")
  medioPago       String?          @default("efectivo") @map("medio_pago")
  esRetiro        Boolean          @default(false) @map("es_retiro")
  totalUnidades   Int              @default(0) @map("total_unidades")
  totalImporte    Float            @default(0) @map("total_importe")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  clienteId       String           @map("id_cliente")
  turno           String?
  ubicacionId     String?          @map("id_ubicacion")
  totalPacks      Int              @default(0) @map("total_packs")
  abonado         Boolean          @default(false)
  detalles        DetallePedido[]
  entregas        Entrega[]
  movimientosCaja MovimientoCaja[]
  cliente         Cliente          @relation(fields: [clienteId], references: [id])
  ubicacion       Ubicacion?       @relation(fields: [ubicacionId], references: [id])

  @@map("pedidos")
}

model DetallePedido {
  id                     String       @id @default(uuid())
  cantidad               Int
  precioUnitario         Float        @map("precio_unitario")
  observaciones          String?
  pedidoId               String       @map("id_pedido")
  presentacionId         String       @map("id_presentacion")
  loteId                 String?      @map("id_lote")
  costoUnitarioHistorico Float?       @map("costo_unitario_historico")
  nroPack                Int?         @map("nro_pack")
  lote                   Lote?        @relation(fields: [loteId], references: [id])
  pedido                 Pedido       @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  presentacion           Presentacion @relation(fields: [presentacionId], references: [id])

  @@map("detalle_pedidos")
}

model Ruta {
  id                String               @id @default(uuid())
  fecha             DateTime
  zona              String?
  turno             String?
  horaSalida        DateTime?            @map("hora_salida")
  horaRegreso       DateTime?            @map("hora_regreso")
  kmRecorridos      Float                @default(0) @map("km_recorridos")
  costoCombustible  Float                @default(0) @map("costo_combustible")
  tempSalida        Float?               @map("temp_salida")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  choferId          String               @map("id_empleado_chofer")
  ubicacionOrigenId String?              @map("id_ubicacion_origen")
  vehiculoId        String?              @map("id_vehiculo")
  entregas          Entrega[]
  movimientos       MovimientoProducto[]
  chofer            Empleado             @relation("ChoferRuta", fields: [choferId], references: [id])
  ubicacionOrigen   Ubicacion?           @relation("OrigenRuta", fields: [ubicacionOrigenId], references: [id])
  vehiculo          Vehiculo?            @relation("RutaVehiculo", fields: [vehiculoId], references: [id])

  @@map("rutas")
}

model Entrega {
  id                 String               @id @default(uuid())
  horaEntrega        DateTime?            @map("hora_entrega")
  dentroVentana      Boolean              @default(false) @map("dentro_ventana")
  tempEntrega        Float?               @map("temp_entrega")
  unidadesRechazadas Int                  @default(0) @map("unidades_rechazadas")
  motivoRechazo      String?              @map("motivo_rechazo")
  observaciones      String?
  createdAt          DateTime             @default(now())
  rutaId             String               @map("id_ruta")
  pedidoId           String               @map("id_pedido")
  clienteId          String               @map("id_cliente")
  orden              Int                  @default(0)
  cliente            Cliente              @relation(fields: [clienteId], references: [id])
  pedido             Pedido               @relation(fields: [pedidoId], references: [id])
  ruta               Ruta                 @relation(fields: [rutaId], references: [id])
  movimientos        MovimientoProducto[]

  @@map("entregas")
}

model CategoriaGasto {
  id          String           @id @default(uuid())
  nombre      String           @unique
  descripcion String?
  color       String?
  esOperativo Boolean          @default(true) @map("es_operativo")
  activo      Boolean          @default(true)
  gastos      GastoOperativo[]

  @@map("categorias_gasto")
}

model ConfiguracionGlobal {
  id        String   @id @default(uuid())
  clave     String   @unique
  valor     String
  updatedAt DateTime @updatedAt

  @@map("configuracion_global")
}

model GastoOperativo {
  id               String            @id @default(uuid())
  fecha            DateTime
  monto            Float
  descripcion      String
  recurrente       Boolean           @default(false)
  categoriaId      String            @map("id_categoria")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  ubicacionId      String?           @map("id_ubicacion")
  vehiculoId       String?           @map("id_vehiculo")
  kmVehiculo       Int?              @map("km_vehiculo")
  taller           String?
  categoria        CategoriaGasto    @relation(fields: [categoriaId], references: [id])
  ubicacion        Ubicacion?        @relation(fields: [ubicacionId], references: [id])
  vehiculo         Vehiculo?         @relation(fields: [vehiculoId], references: [id])
  movimientosStock MovimientoStock[]

  @@map("gastos_operativos")
}

model MovimientoCaja {
  id           String                 @id @default(uuid())
  fecha        DateTime               @default(now())
  tipo         String
  concepto     String
  monto        Float
  medioPago    String                 @default("efectivo") @map("medio_pago")
  cajaOrigen   String?                @map("caja_origen")
  descripcion  String?
  createdAt    DateTime               @default(now())
  pedidoId     String?                @map("id_pedido")
  gastoId      String?                @map("id_gasto")
  rendicionId  String?                @map("id_rendicion")
  pedido       Pedido?                @relation(fields: [pedidoId], references: [id])
  rendicion    RendicionChofer?       @relation(fields: [rendicionId], references: [id])
  movimientoMp MovimientoMercadoPago?

  @@map("movimientos_caja")
}

model RendicionChofer {
  id              String           @id @default(uuid())
  fecha           DateTime         @default(now())
  montoEsperado   Float            @default(0) @map("monto_esperado")
  montoEntregado  Float?           @map("monto_entregado")
  diferencia      Float?
  estado          String           @default("pendiente")
  observaciones   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  choferId        String           @map("id_chofer")
  movimientosCaja MovimientoCaja[]
  chofer          Empleado         @relation("RendicionesChofer", fields: [choferId], references: [id])

  @@map("rendiciones_chofer")
}

model SaldoCaja {
  id        String   @id @default(uuid())
  tipo      String   @unique
  saldo     Float    @default(0)
  updatedAt DateTime @updatedAt

  @@map("saldos_caja")
}

model ConceptoCaja {
  id     String  @id @default(uuid())
  clave  String  @unique
  nombre String
  activo Boolean @default(true)

  @@map("conceptos_caja")
}

model ConceptoSalarial {
  id              String            @id @default(uuid())
  nombre          String            @unique
  tipo            String            // "REMUNERATIVO", "NO_REMUNERATIVO", "DESCUENTO"
  esPorcentaje    Boolean           @default(false) @map("es_porcentaje")
  valorPorDefecto Float?            @map("valor_por_defecto")
  activo          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  items           ItemLiquidacion[]

  @@map("conceptos_salariales")
}

model ItemLiquidacion {
  id                 String            @id @default(uuid())
  liquidacionId      String            @map("id_liquidacion")
  conceptoSalarialId String            @map("id_concepto")
  montoCalculado     Float             @map("monto_calculado")
  detalle            String?           // Por ej: "10% sobre base"
  createdAt          DateTime          @default(now())

  liquidacion        LiquidacionSueldo @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)
  concepto           ConceptoSalarial  @relation(fields: [conceptoSalarialId], references: [id])

  @@map("items_liquidacion")
}

model DocumentoEmpleado {
  id               String    @id @default(uuid())
  empleadoId       String    @map("id_empleado")
  tipoDocumento    String    @map("tipo_documento") // "DNI", "ALTA_AFIP", "CERTIFICADO_MEDICO", "CONTRATO", "OTRO"
  archivoUrl       String    @map("archivo_url")
  fechaVencimiento DateTime? @map("fecha_vencimiento")
  observaciones    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  empleado         Empleado  @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  @@map("documentos_empleado")
}

model FichadaEmpleado {
  id             String        @id @default(uuid())
  fechaHora      DateTime      @map("fecha_hora")
  tipo           String
  origen         String        @default("reloj")
  createdAt      DateTime      @default(now())
  empleadoId     String        @map("id_empleado")
  tipoLicenciaId String?       @map("id_tipo_licencia")
  empleado       Empleado      @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  tipoLicencia   TipoLicencia? @relation(fields: [tipoLicenciaId], references: [id])

  @@map("fichadas_empleados")
}

model TipoLicencia {
  id            String            @id @default(uuid())
  nombre        String            @unique
  descripcion   String?
  conGoceSueldo Boolean           @default(false) @map("con_goce_sueldo")
  activo        Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  fichadas      FichadaEmpleado[]

  @@map("tipos_licencia")
}

model Feriado {
  id        String   @id @default(uuid())
  fecha     DateTime @unique
  nombre    String
  createdAt DateTime @default(now())

  @@map("feriados")
}

model PrestamoEmpleado {
  id             String          @id @default(uuid())
  fechaSolicitud DateTime        @default(now()) @map("fecha_solicitud")
  montoTotal     Float           @map("monto_total")
  cantidadCuotas Int             @map("cantidad_cuotas")
  estado         String          @default("activo")
  frecuencia     String          @default("SEMANAL")
  modoInicio     String          @default("INMEDIATO")
  observaciones  String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  empleadoId     String          @map("id_empleado")
  cuotas         CuotaPrestamo[]
  empleado       Empleado        @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  @@map("prestamos_empleados")
}

model CuotaPrestamo {
  id               String             @id @default(uuid())
  numeroCuota      Int                @map("numero_cuota")
  monto            Float
  estado           String             @default("pendiente")
  mesAnio          String             @map("mes_anio")
  fechaVencimiento DateTime           @default(now()) @map("fecha_vencimiento")
  fechaPago        DateTime?          @map("fecha_pago")
  prestamoId       String             @map("id_prestamo")
  liquidacionId    String?            @map("id_liquidacion")
  liquidacion      LiquidacionSueldo? @relation(fields: [liquidacionId], references: [id])
  prestamo         PrestamoEmpleado   @relation(fields: [prestamoId], references: [id], onDelete: Cascade)

  @@map("cuotas_prestamos")
}

model LiquidacionSueldo {
  id                  String          @id @default(uuid())
  periodo             String
  tipo                String          @default("NORMAL") // "NORMAL", "FINAL"
  fechaGeneracion     DateTime        @default(now()) @map("fecha_generacion")
  sueldoProporcional  Float           @default(0) @map("sueldo_proporcional")
  horasNormales       Float           @default(0) @map("horas_normales")
  montoHorasNormales  Float           @default(0) @map("monto_horas_normales")
  horasExtras         Float           @default(0) @map("horas_extras")
  montoHorasExtras    Float           @default(0) @map("monto_horas_extras")
  horasFeriado        Float           @default(0) @map("horas_feriado")
  montoHorasFeriado   Float           @default(0) @map("monto_horas_feriado")
  ajusteHorasExtras   Float           @default(0) @map("ajuste_horas_extras")
  descuentosPrestamos Float           @default(0) @map("descuentos_prestamos")
  totalNeto           Float           @default(0) @map("total_neto")
  estado              String          @default("generado")
  empleadoId          String          @map("id_empleado")
  desglose            Json?           @map("desglose")
  cuotasDescontadas   CuotaPrestamo[]
  items               ItemLiquidacion[]
  empleado            Empleado        @relation(fields: [empleadoId], references: [id])

  @@map("liquidaciones_sueldos")
}

model RolEmpleado {
  id                String     @id @default(uuid())
  nombre            String     @unique
  descripcion       String?
  color             String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  permisoCaja       Boolean    @default(false)
  permisoCostos     Boolean    @default(false)
  permisoPersonal   Boolean    @default(false)
  permisoProduccion Boolean    @default(false)
  permisoStock      Boolean    @default(false)
  permisoDashboard  Boolean    @default(false)
  jornal            Float      @default(0)
  valorHoraExtra    Float      @default(0) @map("valor_hora_extra")
  cicloPago         CicloPago  @default(SEMANAL) @map("ciclo_pago")
  empleados         Empleado[]

  @@map("roles_empleado")
}

model Area {
  id            String     @id @default(uuid())
  nombre        String     @unique
  descripcion   String?
  color         String?
  activo        Boolean    @default(true)
  responsableId String?    @map("id_responsable")
  parentId      String?    @map("id_area_padre")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  responsable   Empleado?  @relation("ResponsableArea", fields: [responsableId], references: [id])
  parent        Area?      @relation("AreaJerarquia", fields: [parentId], references: [id])
  children      Area[]     @relation("AreaJerarquia")
  puestos       Puesto[]
  empleados     Empleado[] @relation("EmpleadoArea")

  @@map("areas")
}

model Puesto {
  id              String     @id @default(uuid())
  nombre          String
  descripcion     String?
  nivelJerarquico Int        @default(0) @map("nivel_jerarquico")
  areaId          String     @map("id_area")
  activo          Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  area            Area       @relation(fields: [areaId], references: [id])
  empleados       Empleado[] @relation("EmpleadoPuesto")

  @@map("puestos")
}

model TurnoTrabajo {
  id                String     @id @default(uuid())
  nombre            String     @unique
  descripcion       String?
  horaInicio        String     @map("hora_inicio") // Formato "HH:mm"
  horaFin           String     @map("hora_fin")    // Formato "HH:mm"
  toleranciaMinutos Int        @default(15) @map("tolerancia_minutos")
  activo            Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  empleados         Empleado[] @relation("EmpleadoTurno")

  @@map("turnos_trabajo")
}

model ConceptoProduccion {
  id           String               @id @default(uuid())
  nombre       String               @unique
  descripcion  String?
  activo       Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  asignaciones AsignacionOperario[]

  @@map("conceptos_produccion")
}

model AsignacionOperario {
  id            String             @id @default(uuid())
  fecha         DateTime
  turno         String             @default("AM")
  empleadoId    String             @map("id_empleado")
  conceptoId    String             @map("id_concepto")
  ubicacionId   String             @map("id_ubicacion")
  observaciones String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  concepto      ConceptoProduccion @relation(fields: [conceptoId], references: [id])
  empleado      Empleado           @relation(fields: [empleadoId], references: [id])
  ubicacion     Ubicacion          @relation(fields: [ubicacionId], references: [id])

  @@map("asignaciones_operario")
}

model Vehiculo {
  id               String                  @id @default(uuid())
  patente          String                  @unique
  marca            String
  modelo           String
  anio             Int
  alias            String?
  kmActual         Int                     @default(0) @map("km_actual")
  kmProximoService Int?                    @map("km_proximo_service")
  avisoKmsAntes    Int                     @default(2000) @map("aviso_kms_antes")
  estado           String                  @default("disponible")
  activo           Boolean                 @default(true)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  asignaciones     AsignacionVehiculo[]    @relation("AsignacionesVehiculo")
  gastos           GastoOperativo[]
  kilometrajes     KilometrajeVehiculo[]
  mantenimientos   MantenimientoVehiculo[]
  rutas            Ruta[]                  @relation("RutaVehiculo")
  vencimientos     VencimientoVehiculo[]

  @@map("vehiculos")
}

model AsignacionVehiculo {
  id         String   @id @default(uuid())
  fecha      DateTime
  turno      String
  empleadoId String   @map("id_empleado")
  vehiculoId String   @map("id_vehiculo")
  kmInicio   Int?     @map("km_inicio")
  kmFin      Int?     @map("km_fin")
  novedades  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  empleado   Empleado @relation("AsignacionesVehiculo", fields: [empleadoId], references: [id])
  vehiculo   Vehiculo @relation("AsignacionesVehiculo", fields: [vehiculoId], references: [id])

  @@unique([fecha, turno, empleadoId])
  @@unique([fecha, turno, vehiculoId])
  @@map("asignaciones_vehiculo")
}

model Inasistencia {
  id               String   @id @default(uuid())
  empleadoId       String   @map("id_empleado")
  fecha            DateTime
  tipo             String   // "INJUSTIFICADA", "CON_AVISO_INJUSTIFICADA", "JUSTIFICADA_PAGA", "JUSTIFICADA_NO_PAGA"
  motivo           String?
  tieneCertificado Boolean  @default(false) @map("tiene_certificado")
  observaciones    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  empleado         Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  @@map("inasistencias_empleado")
}

model AlertaAusentismo {
  id              String   @id @default(uuid())
  tipoInasistencia String   @map("tipo_inasistencia") // "INJUSTIFICADA", "CON_AVISO_INJUSTIFICADA", etc.
  limiteMaximo    Int      @map("limite_maximo")
  periodoDias     Int      @default(30) @map("periodo_dias") // Ej: 3 injustificadas en 30 días
  accionSugerida  String?  @map("accion_sugerida") // "Sanción", "Aviso", "Despido"
  activo          Boolean  @default(true)
  
  @@map("alertas_ausentismo")
}


model KilometrajeVehiculo {
  id            String   @id @default(uuid())
  vehiculoId    String   @map("id_vehiculo")
  fecha         DateTime @default(now())
  kmRegistrado  Int      @map("km_registrado")
  observaciones String?
  createdAt     DateTime @default(now())
  vehiculo      Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)

  @@map("kilometrajes_vehiculo")
}

model VencimientoVehiculo {
  id               String    @id @default(uuid())
  vehiculoId       String    @map("id_vehiculo")
  tipo             String
  fechaVencimiento DateTime? @map("fecha_vencimiento")
  kmVencimiento    Int?      @map("km_vencimiento")
  kmAviso          Int?      @map("km_aviso")
  observaciones    String?
  notificado       Boolean   @default(false)
  diasAviso        Int       @default(30) @map("dias_aviso")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  vehiculo         Vehiculo  @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)

  @@map("vencimientos_vehiculo")
}

model MantenimientoVehiculo {
  id          String   @id @default(uuid())
  vehiculoId  String   @map("id_vehiculo")
  fecha       DateTime @default(now())
  tipo        String
  taller      String?
  costo       Float    @default(0)
  descripcion String
  kilometraje Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  vehiculo    Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)

  @@map("mantenimientos_vehiculo")
}

model MovimientoMercadoPago {
  id                String          @id @default(uuid())
  mpId              String          @unique @map("mp_id")
  tipo              String
  montoBruto        Float           @map("monto_bruto")
  montoNeto         Float           @map("monto_neto")
  comisionMp        Float           @default(0) @map("comision_mp")
  metodoPago        String?         @map("metodo_pago")
  estado            String
  fechaCreacionMp   DateTime        @map("fecha_creacion_mp")
  fechaAprobacionMp DateTime?       @map("fecha_aprobacion_mp")
  descripcion       String?
  referenciaExterna String?         @map("referencia_externa")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  movimientoCajaId  String?         @unique @map("id_movimiento_caja")
  movimientoCaja    MovimientoCaja? @relation(fields: [movimientoCajaId], references: [id])

  @@map("movimientos_mercado_pago")
}

model RequerimientoProduccion {
  id             String        @id @default(uuid())
  fecha          DateTime
  turno          String
  productoId     String?       @map("id_producto")
  cantidad       Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  presentacionId String?       @map("id_presentacion")
  destino        String        @default("FABRICA")
  shipmentId     String?       @map("shipment_id")
  textoOriginal  String?       @map("texto_original")
  presentacion   Presentacion? @relation(fields: [presentacionId], references: [id])
  producto       Producto?     @relation(fields: [productoId], references: [id])

  @@map("requerimientos_produccion")
}

model PlanificacionDescuento {
  id        String   @id @default(uuid())
  fecha     DateTime
  turno     String
  createdAt DateTime @default(now())

  @@unique([fecha, turno])
  @@map("planificacion_descuentos")
}

enum CicloPago {
  DIARIO
  SEMANAL
  MENSUAL
}
